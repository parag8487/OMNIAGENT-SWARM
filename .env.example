# ===== LLM API Configuration =====
# Supports any OpenAI-compatible API endpoint.
# Recommended: Google Gemini (free tier available)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-2.0-flash

# ===== Google Gemini Configuration (PRIMARY) =====
# Get your FREE key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.0-flash

# ===== Zep Cloud — Graph Memory =====
# Free tier available at: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Optional: Boost/Secondary LLM =====
LLM_BOOST_API_KEY=your_secondary_api_key_here
LLM_BOOST_BASE_URL=your_secondary_base_url_here
LLM_BOOST_MODEL_NAME=qwen-max

# ===== Operational Mode =====
# False = Real simulation using LLM agents (requires API keys above)
# True  = Demo/synthetic mode (no API keys required)
DEMO_MODE=False
