# OmniAgent Swarm - Environment Variables Template
# Copy this file to .env and fill in your values

# Flask Configuration
SECRET_KEY=swarm-secret-key-change-me
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
DEMO_MODE=False

# LLM Configuration (Generic OpenAI Compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# Google Gemini Configuration (Takes priority over generic LLM if set)
# Get your key at https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash

# Zep Cloud Configuration
# Get your key at https://getzep.com/
ZEP_API_KEY=

# Simulation Configuration
OASIS_DEFAULT_MAX_ROUNDS=10
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
REPORT_AGENT_TEMPERATURE=0.5
